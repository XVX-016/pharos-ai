# Pharos AI Environment Configuration
# Copy this file to .env and update with your values

# ==============================================================================
# GENERAL SETTINGS
# ==============================================================================
ENV=development
DEBUG=True

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================
# Generate a secure secret key for production:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DB_NAME=pharos_db
DB_USER=pharos_user
DB_PASSWORD=pharos_password
DB_HOST=db
DB_PORT=5442

# Full database URL (alternative to individual settings)
# DATABASE_URL=postgresql://pharos_user:pharos_password@db:5432/pharos_db

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6389
REDIS_PASSWORD=redis_password_for_production

# ==============================================================================
# CELERY CONFIGURATION
# ==============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==============================================================================
# API KEYS
# ==============================================================================
# OpenAI API Key for AI features
OPENAI_API_KEY=your-openai-api-key-here

# ==============================================================================
# DJANGO SETTINGS
# ==============================================================================
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# CORS settings for frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Static and media files
STATIC_URL=/static/
MEDIA_URL=/media/

# ==============================================================================
# FRONTEND SETTINGS
# ==============================================================================
# Frontend API URLs
VITE_API_URL=http://localhost:8100
VITE_WS_URL=ws://localhost:8100

# ==============================================================================
# SERVICE PORTS
# ==============================================================================
# Backend service port
BACKEND_PORT=8100

# Frontend service port
FRONTEND_PORT=3100

# Flower monitoring port
FLOWER_PORT=5565

# Nginx ports
HTTP_PORT=8080
HTTPS_PORT=8443

# ==============================================================================
# FLOWER MONITORING
# ==============================================================================
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# ==============================================================================
# PRODUCTION SECURITY SETTINGS
# ==============================================================================
# Set these to True in production with HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ==============================================================================
# EMAIL CONFIGURATION (Optional)
# ==============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@pharos-ai.com

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# ==============================================================================
# SENTRY (Optional - Error Tracking)
# ==============================================================================
# SENTRY_DSN=your-sentry-dsn-here

# ==============================================================================
# AWS S3 (Optional - For media storage in production)
# ==============================================================================
# USE_S3=False
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=pharos-media
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-cloudfront-domain

# ==============================================================================
# MONITORING & ANALYTICS (Optional)
# ==============================================================================
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# MIXPANEL_TOKEN=your-mixpanel-token

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# ==============================================================================
# BACKUP SETTINGS
# ==============================================================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30